# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Banco de dados
# Formato: postgresql+psycopg://<usuario>:<senha>@<host>:<porta>/<banco>
DATABASE_URL=postgresql+psycopg://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>

# pgVector
PG_VECTOR_COLLECTION_NAME=documents

# Ingestão
PDF_PATH=document.pdf

# Busca semântica
# Score mínimo de similaridade (0.0 a 1.0) — chunks abaixo disso são descartados
SIMILARITY_THRESHOLD=0.5
